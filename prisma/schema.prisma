

generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Preorder {
  id           String   @id @default(cuid())
  orderNumber  String   @unique
  customerName String
  email        String
  product      String
  quantity     Int
  price        Float
  status       String   @default("active")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
